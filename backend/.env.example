# ─── Database ──────────────────────────────────────────────────────────────────
# Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Must be identical to BETTER_AUTH_SECRET in the frontend .env
BETTER_AUTH_SECRET=replace-with-a-long-random-string-at-least-32-chars

# ─── AI ────────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
